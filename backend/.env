# Django
SECRET_KEY=django-insecure-dev-key-tmwork-2026
DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.dev

# Для Splite3
# # Database
DB_ENGINE=sqlite3
DB_NAME=tmwork_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Если захочешь перейти на PostgreSQL:
# Установи PostgreSQL.
# Создай базу данных с именем tmwork_dev.
# В файле .env измени:

# Для Postgress
# DB_ENGINE=postgres
# DB_NAME=tmwork_dev
# DB_USER=твой_логин (обычно postgres)
# DB_PASSWORD=твой_пароль
# Снова выполни python backend\manage.py migrate

# CORS
CORS_ALLOWED_ORIGINS=*

# Email Settings (Примеры настроек)

# --- Вариант 1: Gmail ---
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your_email@gmail.com
# EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx (Пароль приложения)

# --- Вариант 2: Mail.ru ---
# EMAIL_HOST=smtp.mail.ru
# EMAIL_PORT=465
# EMAIL_USE_TLS=False
# EMAIL_USE_SSL=True
# EMAIL_HOST_USER=your_email@mail.ru
# EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx (Пароль приложения)

# --- Текущие настройки ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=no-reply@tmwork.tm

# Чтобы оставить вывод в консоль для тестов (не отправлять реально), раскомментируйте строку ниже:
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
