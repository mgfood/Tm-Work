# TmWork .gitignore (Team Friendly Version)
# Игнорируем только тяжелое, всё остальное (включая .env) летит в гит для друга.

# Тяжелые зависимости
node_modules/
__pycache__/
*.py[cod]
*$py.class
*.so

# Виртуальное окружение
.venv/
venv/
ENV/
env/
.python-version

# Сборки
dist/
build/
*.egg-info/

# Системные файлы
.DS_Store
Thumbs.db

# Настройки IDE (можно оставить, если работаете в одном редакторе, но лучше игнорировать)
.vscode/
.idea/

# База данных (SQLite)
# Обычно игнорируется, но если хочешь делиться данными, можно закомментировать строку ниже
# db.sqlite3

# ВНИМАНИЕ: .env и другие настройки НЕ игнорируются, чтобы друг мог сразу запуститься

# nginx
nginx/